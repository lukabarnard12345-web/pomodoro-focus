# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Spotify — https://developer.spotify.com/dashboard → Create App
# Set redirect URI: http://localhost:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google — https://console.cloud.google.com → APIs & Services → OAuth 2.0 Credentials
# Scopes: calendar.readonly, calendar.events
# Set redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
